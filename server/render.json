{
  "name": "akpu4all-api",
  "description": "Akpu4All Food Ordering Platform - Backend API",
  "keywords": ["nodejs", "express", "mongodb", "api"],
  "repository": "https://github.com/Ozeal51/Akpu4All-site",
  "success_url": "/health",
  "env": {
    "MONGO_URI": {
      "description": "MongoDB Atlas connection string",
      "value": "mongodb+srv://user:password@cluster.mongodb.net/akpu4all?retryWrites=true&w=majority&appName=Akpu4all"
    },
    "MONGO_DB_NAME": {
      "description": "MongoDB database name used when the URI path is missing",
      "value": "akpu4all"
    },
    "JWT_SECRET": {
      "description": "Secret key for JWT token signing. Generate a random string.",
      "generator": "secret"
    },
    "JWT_EXPIRE": {
      "description": "JWT token expiration time",
      "value": "7d"
    },
    "CLIENT_URLS": {
      "description": "Comma-separated list of allowed client origins for CORS",
      "value": "https://akpu4all-client.vercel.app,https://akpu4all.com.ng,https://www.akpu4all.com.ng,http://localhost:5173,http://localhost:5174"
    },
    "NODE_ENV": {
      "description": "Node environment",
      "value": "production"
    }
  },
  "buildCommand": "npm run build",
  "startCommand": "npm start"
}
